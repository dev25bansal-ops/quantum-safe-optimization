    )
    debug: bool = Field(default=False, alias="DEBUG")

    # Server settings
    host: str = Field(default="0.0.0.0", alias="API_HOST"),  # noqa: S104 - Accepting connections from all interfaces
    port: int = Field(default=8000, alias="API_PORT", ge=1, le=65535)
