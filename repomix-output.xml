# Secret management for Quantum-Safe Optimization Platform
# Uses External Secrets Operator with Azure Key Vault
# NOTE: For local development, use stringData below
# For production, uncomment ExternalSecret resources

apiVersion: v1
kind: Secret
metadata:
  name: quantum-api-secrets
  namespace: quantum-platform
  labels:
    app: quantum-api
    component: secrets
  annotations:
    # Indicates these are managed externally in production
    external-secrets.io/managed: "true"
type: Opaque
stringData:
  # ============================================================
  # DEVELOPMENT ONLY - Replace with External Secrets in production
  # ============================================================
  
  # JWT and Auth
  JWT_SECRET: "development-only-replace-in-production"
  
  # Cosmos DB (use emulator key for local dev)
  COSMOS_KEY: "C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw=="
  
  # Redis (optional in dev)
  REDIS_PASSWORD: ""
  
  # Quantum Backends (leave empty in dev)
  IBM_QUANTUM_TOKEN: ""
  DWAVE_API_TOKEN: ""
  AWS_ACCESS_KEY_ID: ""
  AWS_SECRET_ACCESS_KEY: ""

---
# Azure Key Vault ClusterSecretStore
# Requires: external-secrets operator and Azure Workload Identity
apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: azure-key-vault
spec:
  provider:
    azurekv:
      # Key Vault URL from Terraform output
      vaultUrl: "https://qsop-prod-kv.vault.azure.net/"
      authType: WorkloadIdentity
      serviceAccountRef:
        name: quantum-api
        namespace: quantum-platform

---
# ExternalSecret for production secrets from Azure Key Vault
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: quantum-api-external-secrets
  namespace: quantum-platform
  labels:
    app: quantum-api
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: azure-key-vault
    kind: ClusterSecretStore
  target:
    name: quantum-api-secrets
    creationPolicy: Owner
    template:
      type: Opaque
      metadata:
        labels:
          app: quantum-api
        annotations:
          reloader.stakater.com/match: "true"
  data:
    # JWT Secret
    - secretKey: JWT_SECRET
      remoteRef:
        key: jwt-secret
    
    # Cosmos DB Credentials
    - secretKey: COSMOS_KEY
      remoteRef:
        key: cosmos-primary-key
    - secretKey: COSMOS_CONNECTION_STRING
      remoteRef:
        key: cosmos-connection-string
    
    # Redis
    - secretKey: REDIS_PASSWORD
      remoteRef:
        key: redis-password
    
    # Quantum Backend Tokens
    - secretKey: IBM_QUANTUM_TOKEN
      remoteRef:
        key: ibm-quantum-token
    - secretKey: DWAVE_API_TOKEN
      remoteRef:
        key: dwave-api-token
    - secretKey: AWS_ACCESS_KEY_ID
      remoteRef:
        key: aws-access-key
    - secretKey: AWS_SECRET_ACCESS_KEY
      remoteRef:
        key: aws-secret-key
    
    # PQC Keys
    - secretKey: PQC_SIGNING_KEY
      remoteRef:
        key: pqc-signing-key
    - secretKey: PQC_ENCRYPTION_KEY
      remoteRef:
        key: pqc-encryption-key

---
# SecretProviderClass for Azure Key Vault CSI Driver (alternative approach)
apiVersion: secrets-store.csi.x-k8s.io/v1
kind: SecretProviderClass
metadata:
  name: quantum-api-keyvault
  namespace: quantum-platform
spec:
  provider: azure
  parameters:
    usePodIdentity: "false"
    useVMManagedIdentity: "false"
    clientID: ""  # Set via Workload Identity
    keyvaultName: "qsop-prod-kv"
    tenantId: ""  # Azure tenant ID
    objects: |
      array:
        - |
          objectName: jwt-secret
          objectType: secret
        - |
          objectName: cosmos-primary-key
          objectType: secret
        - |
          objectName: cosmos-connection-string
          objectType: secret
  secretObjects:
    - secretName: quantum-api-secrets-csi
      type: Opaque
      data:
        - objectName: jwt-secret
          key: JWT_SECRET
        - objectName: cosmos-primary-key
          key: COSMOS_KEY
</file>

