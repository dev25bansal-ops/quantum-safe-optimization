                                        <div class="problem-specs">
                                            <span><strong>Complexity:</strong> NP-complete</span>
                                            <span><strong>Applications:</strong> Scheduling, register allocation</span>
                                            <span><strong>Qubits:</strong> n × k (n vertices, k colors)</span>
                                        </div>
                                    </div>
                                </div>
