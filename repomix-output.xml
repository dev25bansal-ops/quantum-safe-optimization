                <button class="btn btn-outline" onclick="closeCompareModal()">Close</button>
                <button class="btn btn-primary" onclick="exportComparison()">
                    <i class="fas fa-download"></i> Export Comparison
                </button>
            </div>
        </div>
    </div>

    <!-- Component System - Load before dashboard -->
    <script type="module">
        import Component from './js/components/Component.js';
        import ToastContainer from './js/components/ToastContainer.js';
        import Modal from './js/components/Modal.js';
        import ConfirmModal from './js/components/Modal.js';
        import AuthModal from './js/components/AuthModal.js';

        // Initialize auth modal
        const authModal = new AuthModal();
        window.authModal = authModal;

        // Expose to global scope for compatibility
        window.Component = Component;
        window.ToastContainer = ToastContainer;
        window.Modal = Modal;
        window.ConfirmModal = ConfirmModal;
        window.AuthModal = AuthModal;
        
        // Initialize global toast container
        window.toastContainer = new ToastContainer();
        window.toastContainer.mount(document.body);
        
        // Make toast functions available globally
        window.showSuccess = (title, message, duration) => window.toastContainer.success(title, message, duration);
        window.showError = (title, message, duration) => window.toastContainer.error(title, message, duration);
        window.showWarning = (title, message, duration) => window.toastContainer.warning(title, message, duration);
        window.showInfo = (title, message, duration) => window.toastContainer.info(title, message, duration);
    </script>

    <!-- Dashboard JavaScript - ES6 Modules -->
    <script type="module" src="js/dashboard-modular.js"></script>

    <script nomodule src="js/dashboard.js"></script>

    <!-- Component System Scripts -->
    <script type="module">
        import { Component } from './js/components/Component.js';
        import { OptimizationSuggestionCard } from './js/components/OptimizationSuggestionCard.js';
        import { ToastContainer } from './js/components/ToastContainer.js';
        import { Modal, ConfirmModal } from './js/components/Modal.js';
        import modalManager from './js/components/ModalManager.js';
        import {
            alertDialog, confirmDialog, showModal, showSuccess, showError
        } from './js/components/ModalUtils.js';

        // Make components globally accessible
        window.OptimizationSuggestionCard = OptimizationSuggestionCard;
        window.ToastContainer = ToastContainer;
        window.Modal = Modal;
        window.ConfirmModal = ConfirmModal;
        window.Component = Component;
        window.modalManager = modalManager;
        window.alertDialog = alertDialog;
        window.confirmDialog = confirmDialog;
        window.showModal = showModal;
        window.showSuccess = showSuccess;
        window.showError = showError;

        // Initialize Modal Manager with preview modal
        document.addEventListener('DOMContentLoaded', () => {
            const suggestionContainer = document.getElementById('ai-suggestions-container');
            const problemType = document.getElementById('problem-type');
            const backend = document.getElementById('backend');
            const qaoaLayers = document.getElementById('qaoa-layers');
            const qaoaOptimizer = document.getElementById('qaoa-optimizer');
            const vqeAnsatz = document.getElementById('vqe-ansatz');
            const vqeOptimizer = document.getElementById('vqe-optimizer');

            let suggestionCard = null;

            const updateSuggestions = () => {
                const type = problemType?.value || 'QAOA';
                const selectedBackend = backend?.value || 'local_simulator';

                if (!suggestionCard) {
                    // Remove placeholder and create card
                    const placeholder = document.getElementById('ai-suggestions-placeholder');
                    if (placeholder) placeholder.remove();
                    suggestionContainer.style.display = 'block';
                    
                    suggestionCard = new OptimizationSuggestionCard({
                        container: suggestionContainer,
                        problemType: type,
                        backend: selectedBackend,
                        parameters: { layers: 2, optimizer: 'COBYLA' }
                    });
                    suggestionCard.mount();
                } else {
                    const parameters = {};
                    if (type === 'QAOA') {
                        parameters.layers = qaoaLayers?.value || 2;
                        parameters.optimizer = qaoaOptimizer?.value || 'COBYLA';
                    } else if (type === 'VQE') {
                        parameters.ansatz = vqeAnsatz?.value || 'hardware_efficient';
                        parameters.optimizer = vqeOptimizer?.value || 'L-BFGS-B';
                    }
                    
                    suggestionCard.updateProps({ problemType: type, backend: selectedBackend, parameters });
                }
            };

            // Listen for changes to form fields
            const formFields = [problemType, backend, qaoaLayers, qaoaOptimizer, vqeAnsatz, vqeOptimizer];
            formFields.forEach(field => {
                if (field) {
                    field.addEventListener('change', updateSuggestions);
                    field.addEventListener('input', updateSuggestions);
                }
            });

            // Also update when QAOA/VQE config sections become visible
            const observer = new MutationObserver((mutations) => {
                mutations.forEach((mutation) => {
                    if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
                        const target = mutation.target;
                        if (target.id?.startsWith('config-') && target.style.display !== 'none') {
                            updateSuggestions();
                        }
                    }
                });
            });

            // Observe config sections
            document.querySelectorAll('.config-section').forEach(section => {
                observer.observe(section, { attributes: true, attributeFilter: ['style'] });
            });

            console.log('✅ AI Optimization Suggestions initialized');
        });
    </script>

    <!-- Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js', { scope: '/' })
                    .then(reg => console.log('[SW] Registered:', reg.scope))
                    .catch(err => console.warn('[SW] Registration failed:', err));
            });
        }
    </script>
</body>

</html>
