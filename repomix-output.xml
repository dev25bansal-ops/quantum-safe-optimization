/**
 * Font Awesome Subset - Only icons used in dashboard
 * Reduces ~100KB+ full library to ~15KB
 * 
 * Icons used: search, moon, sun, bell, bell-slash, trash-alt, sync-alt,
 * sign-in-alt, sign-out-alt, cog, server, bolt, atom, wave-square, 
 * magic, project-diagram, flask, th, route, chart-pie, plus-circle,
 * sliders-h, flag, times, download, plus, hashtag, info-circle, lock,
 * clock, ellipsis-h, inbox, spinner, calendar, chart-line, chart-area,
 * arrow-left, angle-left, angle-right, angle-double-left, angle-double-right,
 * eye, check-circle, times-circle, layer-group, user-lock, user-plus,
 * key, cloud-upload-alt, microchip, exclamation-triangle, paper-plane, redo,
 * aws (brand), microsoft (brand)
 */

/* Font Awesome 6 Free - Subset loader */
@font-face {
    font-family: 'Font Awesome 6 Free';
    font-style: normal;
    font-weight: 900;
    font-display: swap;
    src: url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/webfonts/fa-solid-900.woff2') format('woff2');
}

@font-face {
    font-family: 'Font Awesome 6 Brands';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/webfonts/fa-brands-400.woff2') format('woff2');
}

/* Base icon styles */
.fas, .fa-solid {
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    font-style: normal;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    display: inline-block;
    line-height: 1;
}

.fab, .fa-brands {
    font-family: 'Font Awesome 6 Brands';
    font-weight: 400;
    font-style: normal;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    display: inline-block;
    line-height: 1;
}

/* Icon sizes */
.fa-3x { font-size: 3em; }
.fa-2x { font-size: 2em; }
.fa-lg { font-size: 1.25em; }
.fa-sm { font-size: 0.875em; }

/* Animations */
.fa-spin {
    animation: fa-spin 1s infinite linear;
}

@keyframes fa-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

