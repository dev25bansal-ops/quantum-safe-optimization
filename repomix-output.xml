    problem={"Q": qubo_matrix},
    backend="dwave",
    num_reads=1000,
    annealing_time=20
)
```

#### Job Management

```python
# Get job status
job = client.get_job("job-id-123")

# List jobs
jobs = client.list_jobs(status="running", limit=50)

# Cancel job
cancelled = client.cancel_job("job-id-123", reason="User requested")

# Delete job
