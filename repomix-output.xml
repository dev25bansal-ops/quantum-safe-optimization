job = client.submit_qaoa_job(
    problem={"Q": qubo_matrix},
    backend="ibm_quantum",
    p=2,                    # QAOA layers
    shots=1000,             # Measurement shots
    optimizer="COBYLA",     # Classical optimizer
    webhook_url="https://..."  # Optional callback
)

# VQE Job
job = client.submit_vqe_job(
    hamiltonian={"terms": [...]},
    ansatz="uccsd",
    backend="simulator",
    shots=1000
)

# Quantum Annealing Job
