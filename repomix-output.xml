}

.ai-suggestion-icon.optimization {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.2) 0%, rgba(192, 132, 252, 0.1) 100%);
  color: #c4b5fd;
}

.ai-suggestion-icon.compatibility {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(74, 222, 128, 0.1) 100%);
  color: #4ade80;
}

.ai-suggestion-icon i {
  font-size: 16px;
}

.ai-suggestion-content {
  flex: 1;
}

.ai-suggestion-title {
  margin: 0;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.ai-suggestion-title small {
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8px;
}

.ai-suggestion-description {
  margin: 6px 0 0 0;
  font-size: 13px;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.7);
}

.ai-suggestion-improvement {
  margin-top: 8px;
  padding: 8px 12px;
  background: rgba(34, 197, 94, 0.1);
  border-left: 3px solid #22c55e;
  border-radius: 4px;
  font-size: 12px;
  color: #86efac;
}

.ai-suggestion-actions {
  margin-top: 12px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.ai-suggestion-actions .btn {
  font-size: 12px;
  padding: 6px 12px;
}

.ai-suggestion-actions .btn-sm {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 4px;
}

.ai-suggestion-learning-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  margin-top: 16px;
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 20px;
  font-size: 12px;
  color: #a78bfa;
}

.ai-suggestion-learning-badge i {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ============================================================================
 * Dark/Light Theme Support
 * ============================================================================ */

@media (prefers-color-scheme: light) {
  .ai-suggestions-placeholder {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(139, 92, 246, 0.04) 100%);
    border-color: rgba(99, 102, 241, 0.2);
    color: rgba(0, 0, 0, 0.6);
  }

  .ai-optimization-suggestions {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.04) 0%, rgba(139, 92, 246, 0.02) 100%);
    border-color: rgba(99, 102, 241, 0.15);
  }

  .ai-suggestion-item {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(99, 102, 241, 0.1);
  }

  .ai-suggestion-item:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(99, 102, 241, 0.2);
  }

  .ai-suggestion-title {
    color: var(--text-primary-light, #1a1a2e);
  }

  .ai-suggestion-description {
    color: rgba(0, 0, 0, 0.6);
  }
}

/* ============================================================================
 * Responsive Design
 * ============================================================================ */

@media (max-width: 768px) {
  .ai-suggestions-section {
    margin: 20px 0;
  }

  .ai-optimization-suggestions {
    padding: 16px;
  }

  .ai-suggestion-item {
    padding: 12px;
  }

  .ai-suggestion-header {
    gap: 8px;
  }

  .ai-suggestion-icon {
    width: 32px;
    height: 32px;
  }

  .ai-suggestion-title {
    font-size: 14px;
  }

  .ai-suggestion-description {
    font-size: 12px;
  }
}
