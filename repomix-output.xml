class TestParticleSwarm:
    """Test particle swarm optimization."""

    def test_simple_optimization(self):
        """Test PSO on simple problem."""
        problem = create_quadratic_problem(2)

        config = ParticleSwarmConfig(
            swarm_size=30,
            iterations=100,
        )
