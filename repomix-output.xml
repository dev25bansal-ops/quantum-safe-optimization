<file path="infrastructure/k8s/overlays/production/kustomization.yaml">
# Kustomize overlay for production environment
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: quantum-platform

resources:
  - ../../base

# Production-specific name prefix (none for production)
# namePrefix: prod-

# Production labels
commonLabels:
  environment: production
  tier: production

# Production annotations
commonAnnotations:
  deployment.kubernetes.io/revision: "production"

# Image configuration for production
images:
  - name: ghcr.io/quantum-platform/quantum-api
    newTag: latest  # This will be overridden by CI/CD with specific version

# Production-specific patches
patches:
  # Production replicas and resources
  - target:
      kind: Deployment
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/replicas
        value: 5
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/cpu
        value: "500m"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/memory
        value: "1Gi"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/cpu
        value: "2000m"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/memory
        value: "4Gi"

  # Production HPA settings
  - target:
      kind: HorizontalPodAutoscaler
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/minReplicas
        value: 5
      - op: replace
        path: /spec/maxReplicas
        value: 50
      - op: replace
        path: /spec/metrics/0/resource/target/averageUtilization
        value: 60

  # Production PDB - higher availability
  - target:
      kind: PodDisruptionBudget
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/minAvailable
        value: 3

  # Production Ingress
  - target:
      kind: Ingress
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/tls/0/hosts/0
        value: api.quantum-platform.example.com
      - op: replace
        path: /spec/tls/0/secretName
        value: quantum-api-prod-tls
      - op: replace
        path: /spec/rules/0/host
        value: api.quantum-platform.example.com

# Production ConfigMap patches
configMapGenerator:
  - name: quantum-api-config
    behavior: merge
    literals:
      - APP_ENV=production
      - LOG_LEVEL=INFO
      - LOG_FORMAT=json
      - CORS_ORIGINS=https://app.quantum-platform.example.com
      - OTEL_TRACES_SAMPLER_ARG=0.1
      - RATE_LIMIT_DEFAULT=100/minute
      - FEATURE_RESULT_ENCRYPTION=true

# Production secrets reference (external secrets in production)
# secretGenerator:
#   - name: quantum-api-secrets
#     behavior: replace
#     options:
#       disableNameSuffixHash: true
</file>

<file path="infrastructure/k8s/overlays/staging/kustomization.yaml">
# Kustomize overlay for staging environment
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: quantum-platform-staging

resources:
  - ../../base

# Staging-specific name prefix
namePrefix: staging-

# Staging labels
commonLabels:
  environment: staging
  tier: non-production

# Staging annotations
commonAnnotations:
  deployment.kubernetes.io/revision: "staging"

# Image configuration for staging
images:
  - name: ghcr.io/quantum-platform/quantum-api
    newTag: develop

# Staging-specific patches
patches:
  # Reduce replicas for staging
  - target:
      kind: Deployment
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/replicas
        value: 2
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/cpu
        value: "100m"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/memory
        value: "256Mi"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/cpu
        value: "500m"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/memory
        value: "1Gi"

  # Reduce HPA for staging
  - target:
      kind: HorizontalPodAutoscaler
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/minReplicas
        value: 1
      - op: replace
        path: /spec/maxReplicas
        value: 5

  # Reduce PDB for staging
  - target:
      kind: PodDisruptionBudget
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/minAvailable
        value: 1

  # Update Ingress host for staging
  - target:
      kind: Ingress
      name: quantum-api
    patch: |
      - op: replace
        path: /spec/tls/0/hosts/0
        value: api-staging.quantum-platform.example.com
      - op: replace
        path: /spec/tls/0/secretName
        value: quantum-api-staging-tls
      - op: replace
        path: /spec/rules/0/host
        value: api-staging.quantum-platform.example.com
      - op: replace
        path: /metadata/annotations/cert-manager.io~1cluster-issuer
        value: letsencrypt-staging

# Staging ConfigMap patches
configMapGenerator:
  - name: quantum-api-config
    behavior: merge
    literals:
      - APP_ENV=staging
      - LOG_LEVEL=DEBUG
      - CORS_ORIGINS=https://app-staging.quantum-platform.example.com
      - OTEL_TRACES_SAMPLER_ARG=1.0
      - RATE_LIMIT_DEFAULT=1000/minute
</file>

