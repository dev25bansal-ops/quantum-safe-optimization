                <!-- QAOA Overview -->
                <div class="algorithm-overview">
                    <div class="overview-card">
                        <div class="overview-icon">🎯</div>
                        <h4>What is QAOA?</h4>
                        <p>QAOA is a hybrid quantum-classical algorithm designed to find approximate solutions to
                            combinatorial optimization problems. It uses parameterized quantum circuits alternating
                            between cost and mixer Hamiltonians.</p>
                    </div>
                </div>

                <div class="dashboard-grid">
                    <!-- Supported Problems -->
                    <div class="card">
                        <div class="card-header">
                            <h3>📊 Supported Problems</h3>
