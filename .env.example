# =============================================================================
# Quantum-Safe Secure Optimization Platform - Configuration
# =============================================================================
# Copy this file to .env and customize for your environment

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
QSOP_ENV=dev
QSOP_DEBUG=true
QSOP_LOG_LEVEL=INFO
QSOP_LOG_FORMAT=json

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
QSOP_API_HOST=0.0.0.0
QSOP_API_PORT=8000
QSOP_API_WORKERS=4
QSOP_API_RELOAD=true
QSOP_API_TITLE=Quantum-Safe Secure Optimization Platform
QSOP_API_VERSION=0.1.0

# CORS settings (comma-separated origins)
QSOP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
QSOP_CORS_ALLOW_CREDENTIALS=true

# Rate limiting
QSOP_RATE_LIMIT_REQUESTS=100
QSOP_RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Security & Cryptography
# -----------------------------------------------------------------------------
# Secret key for JWT and session encryption (generate with: openssl rand -hex 32)
QSOP_SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Post-Quantum Cryptography settings
QSOP_PQC_KEM_ALGORITHM=Kyber512
QSOP_PQC_SIG_ALGORITHM=Dilithium2
QSOP_PQC_HYBRID_MODE=true

# Classical cryptography fallback
QSOP_CLASSICAL_ALGORITHM=AES-256-GCM
QSOP_KEY_DERIVATION=argon2id

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (development)
QSOP_DATABASE_URL=sqlite+aiosqlite:///./data/qsop.db

# PostgreSQL (production)
# QSOP_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qsop

QSOP_DATABASE_POOL_SIZE=10
QSOP_DATABASE_MAX_OVERFLOW=20
QSOP_DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
QSOP_REDIS_URL=redis://localhost:6379/0
QSOP_REDIS_PASSWORD=
QSOP_REDIS_SSL=false
QSOP_REDIS_POOL_SIZE=10

# Cache settings
QSOP_CACHE_TTL=3600
QSOP_CACHE_PREFIX=qsop:

# -----------------------------------------------------------------------------
# Quantum Backend Configuration
# -----------------------------------------------------------------------------
# Quantum simulator settings
QSOP_QUANTUM_BACKEND=aer_simulator
QSOP_QUANTUM_SHOTS=1024
QSOP_QUANTUM_OPTIMIZATION_LEVEL=3

# IBM Quantum (optional - for real hardware)
# QSOP_IBM_QUANTUM_TOKEN=your-ibm-quantum-token
# QSOP_IBM_QUANTUM_HUB=ibm-q
# QSOP_IBM_QUANTUM_GROUP=open
# QSOP_IBM_QUANTUM_PROJECT=main

# Optimization settings
QSOP_OPTIMIZER_MAX_ITERATIONS=1000
QSOP_OPTIMIZER_CONVERGENCE_THRESHOLD=1e-6
QSOP_OPTIMIZER_TIMEOUT=300

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# OpenTelemetry
QSOP_OTEL_ENABLED=true
QSOP_OTEL_SERVICE_NAME=qsop
QSOP_OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Prometheus
QSOP_METRICS_ENABLED=true
QSOP_METRICS_PATH=/metrics

# Structured logging
QSOP_LOG_INCLUDE_TRACE_ID=true

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Health check endpoints
QSOP_HEALTH_CHECK_TIMEOUT=5

# HTTP client settings
QSOP_HTTP_TIMEOUT=30
QSOP_HTTP_MAX_RETRIES=3
QSOP_HTTP_RETRY_BACKOFF=1.0
