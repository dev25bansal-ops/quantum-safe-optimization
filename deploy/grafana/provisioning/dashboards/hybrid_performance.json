    {
      "title": "Hybrid Loop Convergence",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "qsop_hybrid_iteration_value",
          "legendFormat": "Job {{job_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Classical vs Quantum Wall Time (Avg)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(qsop_classical_execution_seconds_sum[5m]) / rate(qsop_classical_execution_seconds_count[5m])",
          "legendFormat": "Classical",
          "refId": "A"
        },
        {
          "expr": "rate(qsop_quantum_execution_seconds_sum[5m]) / rate(qsop_quantum_execution_seconds_count[5m])",
          "legendFormat": "Quantum",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Jobs Submitted by Tenant",
      "type": "barchart",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(qsop_jobs_submitted_total) by (tenant_id)",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Quantum Shots by Tenant",
      "type": "barchart",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(qsop_quantum_shots_total) by (tenant_id)",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ]
    }
  ],
