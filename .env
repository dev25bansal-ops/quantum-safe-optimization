# Quantum-Safe Optimization Platform - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Azure Cosmos DB
# =============================================================================
# For local development with emulator:
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==

# For production (use managed identity):
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# USE_MANAGED_IDENTITY=true

COSMOS_DATABASE=quantum_optimization

# =============================================================================
# Azure Key Vault (Production)
# =============================================================================
# KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# =============================================================================
# Authentication & Security
# =============================================================================
# JWT secret (fallback when PQC signing unavailable)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiration times (seconds)
ACCESS_TOKEN_EXPIRE=3600
REFRESH_TOKEN_EXPIRE=604800

# =============================================================================
# Redis (Celery Task Queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Quantum Backend Credentials
# =============================================================================

# IBM Quantum
IBM_QUANTUM_TOKEN=g9-FS_wucOAn9fPcOGG4yQ-Ba60bj9nYTLRXATPjJpfy
IBM_QUANTUM_CHANNEL=ibm_quantum_platform
# IBM_QUANTUM_INSTANCE=  # Will auto-detect when instance is created

# AWS Braket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_BRAKET_S3_BUCKET=your-braket-results-bucket

# Azure Quantum
AZURE_QUANTUM_SUBSCRIPTION_ID=your-subscription-id
AZURE_QUANTUM_RESOURCE_GROUP=your-resource-group
AZURE_QUANTUM_WORKSPACE=your-quantum-workspace
AZURE_QUANTUM_LOCATION=eastus

# D-Wave
DWAVE_API_TOKEN=your-dwave-api-token
DWAVE_SOLVER=Advantage_system6.4

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Application Insights (Azure)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=xxx

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=quantum-optimization-api

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUANTUM_BACKENDS=true
ENABLE_PQC_ENCRYPTION=true
ENABLE_AUDIT_LOGGING=true
