# Quantum-Safe Optimization Platform - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
QSOP_ENV=dev
QSOP_DEBUG=true
QSOP_LOG_LEVEL=INFO
QSOP_SECRET_KEY=dev-secret-key-change-in-production-32chars

# =============================================================================
# API Server
# =============================================================================
QSOP_API_HOST=127.0.0.1
QSOP_API_PORT=8000
QSOP_API_WORKERS=1
QSOP_API_RELOAD=false

# CORS - Comma-separated list of allowed origins
QSOP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000,http://127.0.0.1:8000

# =============================================================================
# Database
# =============================================================================
QSOP_DATABASE_URL=sqlite+aiosqlite:///./qsop.db

# =============================================================================
# Redis
# =============================================================================
QSOP_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Quantum Backend
# =============================================================================
QSOP_QUANTUM_BACKEND=aer_simulator

# =============================================================================
# PQC Settings
# =============================================================================
QSOP_PQC_KEM_ALGORITHM=Kyber512
QSOP_PQC_SIG_ALGORITHM=Dilithium2

# =============================================================================
# IBM Quantum
# =============================================================================
QSOP_IBM_QUANTUM_TOKEN=g9-FS_wucOAn9fPcOGG4yQ-Ba60bj9nYTLRXATPjJpfy
